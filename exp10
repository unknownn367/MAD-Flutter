// 2. Connect to database using your custom port 3307
$conn = new mysqli("localhost", "root", "", "flutter_db", 3307);

if ($conn->connect_error) {
    die("Connection failed: " . $conn->connect_error);
}

// 3. Fetch all user rows from the table
$sql = "SELECT * FROM users";
$result = $conn->query($sql);

$data = array();

// Loop through rows and pack them into a clean associative array
while($row = $result->fetch_assoc()){
    $data[] = $row;
}

// 4. Convert array to JSON string format for Flutter to read
echo json_encode($data);

$conn->close();
?>




